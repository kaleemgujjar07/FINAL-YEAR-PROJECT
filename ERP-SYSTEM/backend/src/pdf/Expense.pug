doctype html
html
  head
    link(rel="shortcut icon" type="image/png" href="/images/icons/favicon.png")
    meta(name="viewport" content="width=device-width, initial-scale=1")
    style.
      body { width: 100%; margin: 0; padding: 20px; font-family: sans-serif; font-size: 14px; color: #333; }
      h1 { color: #1890ff; padding-bottom: 10px; border-bottom: 2px solid #1890ff; text-transform: uppercase; }
      table { width: 100%; border-collapse: collapse; margin-top: 20px; }
      th, td { padding: 12px; text-align: left; border-bottom: 1px solid #ddd; }
      th { background-color: #f5f5f5; width: 30%; color: #555; }
      .footer { margin-top: 50px; text-align: center; color: #888; font-size: 12px; }
  body
    h1 Expense Receipt
    table
      tbody
        tr
          th Expense Name
          td #{model.name}
        tr
          th Date
          td #{moment(model.date).format(dateFormat)}
        tr
          th Amount
          td #{moneyFormatter({amount: model.amount || 0})}
        tr
          th Category
          td #{model.category}
        tr
          th Ref Number
          td #{model.ref}
        tr
          th Description
          td #{model.description}
    div.footer Document generated by Cognivio
